{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./frontend/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "strict": false,
    "incremental": true,
    "resolveJsonModule": true
  },
  "include": [
    "frontend",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "app",
    "components"
  ]
}
