# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Supabase Configuration (REQUIRED) ───────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Gemini AI Configuration (REQUIRED) ──────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# ─── Local AI (Optional — Ollama fallback) ────────────────────────
# Only needed if you want to use a local Ollama model (e.g. llama3)
LOCAL_AI_URL=http://localhost:11434/api/generate

# ─── Resend Email (REQUIRED for signup OTP emails) ────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
# Sender email: use onboarding@resend.dev for testing (only sends to your own email),
# or add a verified domain at https://resend.com/domains and use noreply@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev
