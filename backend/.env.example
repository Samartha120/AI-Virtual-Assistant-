# Server Configuration
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Firebase Admin (REQUIRED) ───────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
# Optional (defaults to <projectId>.appspot.com if omitted)
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# ─── Grok (xAI) Configuration (REQUIRED) ─────────────────────────
# Create an API key in your xAI console and paste it here.
# NOTE: Do NOT paste your Firebase/Google web API key here (those often start with "AIza").
# If you're using Groq instead of xAI, keys commonly start with "gsk_" and the service will auto-detect the Groq base URL.
GROK_API_KEY=your_grok_api_key_here

# Optional overrides
# GROK_MODEL=grok-2-latest
# GROK_BASE_URL=https://api.x.ai/v1

# ─── Local AI (Optional — Ollama fallback) ────────────────────────
# Only needed if you want to use a local Ollama model (e.g. llama3)
LOCAL_AI_URL=http://localhost:11434/api/generate

# ─── Hugging Face Router (Primary LLM) ────────────────────────────
HF_API_KEY=your_huggingface_api_key
HF_BASE_URL=https://router.huggingface.co/v1
# Optional override
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# ─── Ollama (Local fallback; works only locally) ───────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PRIMARY=qwen2:1.5b
OLLAMA_MODEL_FALLBACK=llama3

# Optional: prints detailed provider/model logs in terminal
LLM_DEBUG=true
