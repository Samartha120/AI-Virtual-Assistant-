# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Firebase Admin (REQUIRED) ───────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
# Optional (defaults to <projectId>.appspot.com if omitted)
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# ─── Grok (xAI) Configuration (REQUIRED) ─────────────────────────
# Create an API key in your xAI console and paste it here.
GROK_API_KEY=your_grok_api_key_here

# Optional overrides
# GROK_MODEL=grok-2-latest
# GROK_BASE_URL=https://api.x.ai/v1

# ─── Local AI (Optional — Ollama fallback) ────────────────────────
# Only needed if you want to use a local Ollama model (e.g. llama3)
LOCAL_AI_URL=http://localhost:11434/api/generate
