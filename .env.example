# ============================================================
# EXAMPLE ENVIRONMENT — copy relevant parts to real .env files
# This file is SAFE TO COMMIT — no real secrets.
# ============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# Only VITE_ prefixed vars are exposed to the browser bundle.
VITE_API_URL=https://nexsus-ai.onrender.com
# ❌  VITE_GEMINI_API_KEY must NOT be here — it would expose the key in the bundle

# For local dev, create .env.local (gitignored) with:
# VITE_API_URL=http://localhost:5000

# ── Backend (backend/.env) ───────────────────────────────────
# These are SERVER-ONLY variables — never accessible in the browser.
# PORT=5000
# NODE_ENV=development
# FRONTEND_URL=http://localhost:3000
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   ← NEVER expose in frontend
# GEMINI_API_KEY=your_gemini_api_key                 ← NEVER expose in frontend
